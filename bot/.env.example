# ── Telegram (optional but recommended for push notifications) ────────────────
# Create a bot via @BotFather on Telegram to get a token.
TELEGRAM_BOT_TOKEN=

# If the auto-registration via /start doesn't work, paste your chat ID here.
# Get it by messaging @userinfobot on Telegram.
TELEGRAM_USER_CHAT_ID=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
